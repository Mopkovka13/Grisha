# Grinya Application Configuration

# ==========================================
# MINIO Credentials
# ==========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=grinya

# ==========================================
# Spring Boot Admin
# ==========================================
# Bcrypt hash for admin password
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD=$2a$10$kTjh3u.L4cVjz4D4G4O8Oey3L5L5L5L5L5L5L5L5L5L5L5L5L5L5L

# ==========================================
# JWT Configuration
# ==========================================
JWT_SECRET=ThisIsAVeryLongSecretKeyForJWTSigningPurposesAtLeast256BitsLongEnoughForHS512
JWT_EXPIRATION=86400000

# ==========================================
# S3/MinIO Configuration
# ==========================================
# Internal endpoint (used by Spring Boot to connect to MinIO)
S3_ENDPOINT=http://minio:9000

# Public endpoint (returned to clients for URLs)
# Can be: /s3 (relative, proxied through nginx)
#         or: https://example.com/s3 (absolute)
S3_PUBLIC_ENDPOINT=/s3

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=grinya

# ==========================================
# FFmpeg Configuration
# ==========================================
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_FFPROBE_PATH=/usr/bin/ffprobe
FFMPEG_TEMP_DIR=/tmp/grinya

# ==========================================
# Database Configuration
# ==========================================
# H2 database file path (inside container: /app/data/grinya)
SPRING_DATASOURCE_URL=jdbc:h2:file:/app/data/grinya

# ==========================================
# nginx Configuration (optional)
# ==========================================
# Change these if you want to use different hostname
NGINX_HOST=localhost
NGINX_PORT=80
